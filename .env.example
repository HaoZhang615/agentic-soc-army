# ── Azure AI Foundry (required) ──────────────────────────────────────────────
AZURE_AI_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>
MODEL_DEPLOYMENT_NAME=gpt-4.1

# ── Azure AI Search (Notebook 04) ────────────────────────────────────────────
AZURE_AI_SEARCH_CONNECTION_NAME=my-search-connection
AZURE_AI_SEARCH_INDEX_NAME=threat-intel-index

# ── MCP Server (Notebook 02) ─────────────────────────────────────────────────
MCP_SERVER_URL=https://<your-mcp-server>/mcp
MCP_SERVER_LABEL=sentinel-mcp

# ── Agent-to-Agent (optional, Notebook 01 advanced) ─────────────────────────
A2A_PROJECT_CONNECTION_ID=<your-a2a-connection-id>

# ── Azure OpenAI (optional, Notebook 05 live evaluation) ─────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>

# ── Application Insights tracer (optional, Notebook 05) ─────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ── Conversation resumption (Notebook 03) ────────────────────────────────────
EXISTING_CONVERSATION_ID=
